<server description="MicroProfile Tutorial Liberty Server">
    <featureManager>
        <platform>microProfile-7.1</platform>
        <platform>jakartaEE-10.0</platform>
        <feature>restfulWS</feature>
        <feature>jsonp</feature>
        <feature>jsonb</feature>
        <feature>cdi</feature>
        <feature>mpConfig</feature>
        <feature>mpOpenAPI</feature>
        <feature>mpHealth</feature>
        <feature>mpMetrics</feature>
        <feature>persistence</feature>
        <feature>jdbc</feature>
    </featureManager>

    <httpEndpoint httpPort="${default.http.port}" httpsPort="${default.https.port}"
                  id="defaultHttpEndpoint" host="*" />

    <!-- Disable authentication for metrics endpoint -->
    <mpMetrics authentication="false" />

    <!-- Derby DataSource Configuration -->
    <dataSource id="DefaultDataSource" jndiName="jdbc/catalogDB" type="javax.sql.DataSource">
        <jdbcDriver libraryRef="derbyLib"/>
        <properties databaseName="catalogDB" createDatabase="create" 
                   connectionAttributes="upgrade=true"/>
    </dataSource>

    <!-- Derby Embedded Driver - using apiTypeVisibility to ignore manifest warnings -->
    <library id="derbyLib" apiTypeVisibility="spec,ibm-api,third-party">
        <fileset dir="${server.config.dir}/derby" includes="*.jar"/>
    </library>

    <!-- Configure classloader to ignore manifest class path warnings -->
    <applicationManager autoExpand="true"/>
    
    <webApplication location="catalog.war" contextRoot="${app.context.root}">
        <classloader delegation="parentLast" commonLibraryRef="derbyLib">
        </classloader>
    </webApplication>

    <!-- Suppress Derby JAR manifest class path warnings -->
    <logging messageSource="message,trace,accessLog,ffdc,audit" 
             suppressSensitiveTrace="true"
             hideMessage="SRVE9967W"/>

</server>