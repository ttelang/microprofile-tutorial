<server description="MicroProfile Payment Service">
    <featureManager>
        <platform>jakartaEE-10.0</platform>
        <feature>restfulWS</feature>
        <feature>jsonb</feature>
        <feature>cdi</feature>
        <feature>mpOpenAPI-4.1</feature>
    </featureManager>

    <!-- Configure logging to show INFO level messages -->
    <!-- Audit logs are captured by the PaymentAudit logger -->
    <logging consoleLogLevel="INFO" 
             traceSpecification="*=info:PaymentAudit=all"
             maxFileSize="50"
             maxFiles="5" />

    <httpEndpoint httpPort="${default.http.port}" httpsPort="${default.https.port}"
                  id="defaultHttpEndpoint" host="*" />

    <webApplication location="payment.war" contextRoot="${app.context.root}"/>

</server>
